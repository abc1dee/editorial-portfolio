                    <th class="p-3 w-16 border-r border-border">Week</th>
                    <th class="p-3 w-28 border-r border-border">Date Range</th>
                    <th class="p-3 border-r border-border">Summary of Accomplished Tasks</th>
                    <th class="p-3 w-48">Key Learnings</th>
                  </tr>
                </thead>
                <tbody>
                  {journalWeeks.map((jw, index) => (
                    <tr class={`journal-row border-b border-border/80 hover:bg-bg-secondary/40 transition-colors ${index % 2 === 0 ? 'bg-bg-primary' : 'bg-bg-secondary/10'}`}>
                      <td class="p-3 font-bold text-text-primary border-r border-border">{jw.week}</td>
                      <td class="p-3 text-text-secondary border-r border-border">{jw.dates}</td>
                      <td class="p-3 text-text-secondary border-r border-border font-light font-sans text-xs">{jw.summary}</td>
                      <td class="p-3 text-text-secondary font-light font-sans text-xs">{jw.learnings}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
              <div id="journal-empty" class="hidden p-6 text-center text-text-muted text-xs font-mono bg-bg-primary">
                No matching journal entries found.
              </div>
            </div>
          </div>
        </article>

      </div>
    </section>
  </main>
  
  <Footer />
</BaseLayout>

<style>
  /* SVG grid pattern background styling */
  .bg-grid-pattern {
    background-image: radial-gradient(var(--border-color) 1px, transparent 1px);
    background-size: 16px 16px;
  }
</style>

<!-- Interactivity script -->
<script>
  // TOC highlights
  const tocLinks = document.querySelectorAll('.toc-link');
  const sections = document.querySelectorAll('article[id]');

  window.addEventListener('scroll', () => {
    let current = "";
    sections.forEach((section) => {
      const sectionTop = (section as HTMLElement).offsetTop;
      if (window.scrollY >= sectionTop - 120) {
        current = section.getAttribute('id') || "";
      }
    });

    tocLinks.forEach((link) => {
      link.classList.remove('active');
      link.classList.remove('text-text-primary');
      link.classList.add('text-text-secondary');
      
      if (link.getAttribute('href') === `#${current}`) {
        link.classList.add('active');
        link.classList.add('text-text-primary');
        link.classList.remove('text-text-secondary');
      }
    });
  });

  // Modules interactive tags filtering
  const filterBtns = document.querySelectorAll('.module-filter-btn');
  const moduleCards = document.querySelectorAll('.module-card');

  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const activeTag = btn.getAttribute('data-tag') || 'all';

      // Update button visual states
      filterBtns.forEach(b => {
        b.classList.remove('bg-text-primary', 'text-bg-primary', 'border-text-primary');
        b.classList.add('text-text-secondary', 'bg-transparent');
      });
      btn.classList.add('bg-text-primary', 'text-bg-primary', 'border-text-primary');
      btn.classList.remove('text-text-secondary', 'bg-transparent');

      // Filter cards
      moduleCards.forEach(card => {
        const cardTags = card.getAttribute('data-tags')?.split(',') || [];
        if (activeTag === 'all' || cardTags.includes(activeTag)) {
          (card as HTMLElement).style.display = 'block';
          setTimeout(() => {
            (card as HTMLElement).style.opacity = '1';
            (card as HTMLElement).style.transform = 'translateY(0)';
          }, 10);
        } else {
          (card as HTMLElement).style.opacity = '0';
          (card as HTMLElement).style.transform = 'translateY(10px)';
          setTimeout(() => {
            (card as HTMLElement).style.display = 'none';
          }, 200);
        }
      });
    });
  });

  // Journal Search filter
  const searchInput = document.getElementById('journal-search') as HTMLInputElement;
  const journalRows = document.querySelectorAll('.journal-row');
  const emptyMessage = document.getElementById('journal-empty');

  if (searchInput) {
    searchInput.addEventListener('input', () => {
      const query = searchInput.value.toLowerCase().trim();
      let hasMatches = false;

      journalRows.forEach(row => {
        const text = row.textContent?.toLowerCase() || "";
        if (text.includes(query)) {
          (row as HTMLElement).style.display = 'table-row';
          hasMatches = true;
        } else {
          (row as HTMLElement).style.display = 'none';
        }
      });

      if (emptyMessage) {
        if (hasMatches) {
          emptyMessage.classList.add('hidden');
        } else {
          emptyMessage.classList.remove('hidden');
        }
      }
    });
  }
</script>
