---
import '../styles/global.css';
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const modules = [
  {
    id: "dashboard",
    num: "2.1",
    title: "Employee Dashboard & Time Clock Widget",
    tags: ["Frontend", "Backend"],
    description: "The main landing page for all authenticated users. Features a real-time server clock synced to Philippine Standard Time (GMT+8), the Time at Work widget for clocking in/out, and a Team Calendar displaying approved leaves and events.",
    features: [
      "Real-time server time display with active polling",
      "Status indicator badge (Timed In / Timed Out)",
      "Latest log entry display with type and timestamp",
      "Team Calendar with admin event management",
      "Developer Time Travel controls for local sandbox testing"
    ],
    tech: ["Dashboard.vue", "TimeAtWork.vue", "DashboardCalendar.vue", "CalendarController", "AdminCalendarEventController"],
    mockType: "dashboard"
  },
  {
    id: "auth-2fa",
    num: "2.2",
    title: "Authentication & Google Authenticator 2FA",
    tags: ["Security", "Backend"],
    description: "A security layer implementing multi-layered authentication: custom login mapping work email, OTP-based and TOTP-based password resets, and a Google Authenticator 2FA setup.",
    features: [
      "Custom login with work_email field mapping",
      "Password reset branching (TOTP vs OTP based on user settings)",
      "Google Authenticator TOTP setup wizard with QR code and backup keys",
      "Require2FA middleware blocking access until verification is complete",
      "2FA settings dashboard for enabling, disabling, and key regeneration"
    ],
    tech: ["spomky-labs/otphp", "qrcode.vue", "TwoFactorCode Model", "Require2FA Middleware"],
    mockType: "auth"
  },
  {
    id: "sso",
    num: "2.3",
    title: "Single Sign-On (SSO) Integration & App Management",
    tags: ["Security", "Backend", "Admin"],
    description: "A full OAuth2/OIDC-based Single Sign-On system enabling authentication via the BeeConnected identity provider. Includes app management dashboards and granular user access controls.",
    features: [
      "Custom Laravel Socialite provider (BeeconnectedProvider.php)",
      "Redirect-based OAuth2 login with callback processing",
      "Automatic local user provisioning and updating from profiles",
      "Admin SSO App manager dashboard (status toggle, user access grids)",
      "SsoConsent.vue authorization flow screen"
    ],
    tech: ["BeeconnectedProvider.php", "SsoApplicationController", "SsoUserAccessManager", "SsoConsent.vue"],
    mockType: "sso"
  },
  {
    id: "webcam",
    num: "2.4",
    title: "Webcam Capture & Photo Verification",
    tags: ["Frontend", "Security"],
    description: "Captures a live webcam photo during time clock events to prevent buddy-punching and verify employee attendance logs.",
    features: [
      "HTML5 MediaDevices API camera stream access",
      "Front-facing camera preference at 1280x720 resolution",
      "Live preview with visual mirror effect",
      "Bandwidth-optimized JPEG Blob transmission",
      "Graceful fallback handling for camera access errors"
    ],
    tech: ["WebcamCapture.vue", "Private Storage", "Multipart Form Handling"],
    mockType: "webcam"
  },
  {
    id: "timelogs",
    num: "2.5",
    title: "Admin Time Logs & Attendance Monitoring",
    tags: ["Admin", "Backend"],
    description: "A comprehensive admin panel providing full visibility into employee time logs with auditable edits and exports.",
    features: [
      "Paginated time log table with types, thumbnails, notes, and IPs",
      "Dynamic filtering by employee, clock type, and date range",
      "Manual time log adjustments and entries for corrections",
      "CSV export with active filters preserved",
      "Soft deletes preserving audit trails"
    ],
    tech: ["Admin\\TimeLogController.php", "Eloquent Eager Loading", "CSV Export Layer"],
    mockType: "timelogs"
  },
  {
    id: "emergency",
    num: "2.6",
    title: "Emergency Contacts Module",
    tags: ["Frontend", "Backend"],
    description: "Self-service emergency contacts portal with custom Philippine phone formatting and validations.",
    features: [
      "Employee-facing CRUD for emergency contact logs",
      "Philippine mobile format validation (09XX / 639XX rules)",
      "Philippine landline format validations",
      "Centralized ValidatesPhilippinePhones validation trait",
      "Toast notification prompts on updates"
    ],
    tech: ["ValidatesPhilippinePhones Trait", "StoreEmergencyContactRequest", "Toast.vue"],
    mockType: "emergency"
  },
  {
    id: "leaves",
    num: "2.7",
    title: "Leave Management Module",
    tags: ["Frontend", "Backend"],
    description: "A complete leave request lifecycle system supporting submissions, multi-status workflows, and team calendar highlights.",
    features: [
      "Leave request creation with type, range, and reason parameters",
      "Database-supported half-day leave calculations",
      "Pending, Approved, Declined lifecycle statuses",
      "Admin dashboard with bulk approvals and decline notes",
      "Calendar visualization of approved leaves"
    ],
    tech: ["LeaveRequestController", "LeaveRequest Model", "DashboardCalendar.vue"],
    mockType: "leaves"
  },
  {
    id: "overtime",
    num: "2.8",
    title: "Overtime Requests Module",
    tags: ["Frontend", "Backend"],
    description: "Allows employees to submit overtime requests for review and gives administrators full approval dashboards.",
    features: [
      "Employee overtime request submission (date, hours, justification)",
      "Cancellation mechanics for pending request entries",
      "Admin dashboard with quick action approve/decline triggers",
      "Role-restricted sidebar navigation items"
    ],
    tech: ["OvertimeRequestController", "EnsureRole Middleware"],
    mockType: "overtime"
  },
  {
    id: "timesheets",
    num: "2.9",
    title: "Timesheets & Attendance Records",
    tags: ["Frontend", "Backend"],
    description: "Dual module for employee timesheet submissions and HR-level manual attendance records.",
    features: [
      "Timesheet logging, weekly submissions, and reviewer audits",
      "HR manual record insertion, updates, and complete deletions",
      "Dynamic view switching based on employee permissions",
      "Auditable changes tracking"
    ],
    tech: ["TimesheetController", "AttendanceController", "Role-based Navigation"],
    mockType: "timesheets"
  },
  {
    id: "payroll",
    num: "2.10",
    title: "Payroll & Payslip Module",
    tags: ["Backend", "Admin", "Frontend"],
    description: "A payroll management suite featuring basic/overtime earnings calculations, government deductions, paid state trackers, and downloads.",
    features: [
      "Payroll dashboards detailing payment statuses and quick actions",
      "Detailed earnings breakdown (Basic, Overtime, Allowances)",
      "Philippine government deduction logic (SSS, PhilHealth, Pag-IBIG, Tax)",
      "One-click 'Mark as Paid' status progression",
      "PDF downloads and CSV spreadsheet exports"
    ],
    tech: ["PayslipController", "AdminPayrollController", "EmployeePayslipEarnings", "PDF Renderer"],
    mockType: "payroll"
  },
  {
    id: "hiring",
    num: "2.11",
    title: "Hiring & Careers Module",
    tags: ["Recruitment", "Frontend", "Backend"],
    description: "A recruitment workflow system consisting of an internal job board manager, status pipeline columns, and a public-facing careers page.",
    features: [
      "Job listing CRUD with status triggers and stats cards",
      "Recruitment pipeline (Pending → Reviewed → HR Interview → Accepted/Rejected)",
      "Inline resume viewer supporting PDF streams with DOCX fallback",
      "Public careers page showing active listings with application forms",
      "Rate-limited submit throttling to prevent spam submissions"
    ],
    tech: ["HiringController", "CareerController", "GuestCareerLayout", "Throttle Middleware"],
    mockType: "hiring"
  },
  {
    id: "directory",
    num: "2.12",
    title: "Employee Directory",
    tags: ["Frontend", "Admin"],
    description: "A company-wide searchable profile directory featuring department filters and privileged status markers.",
    features: [
      "Grid layout of searchable employee profile cards",
      "Department and office location drop-down filters",
      "Role-based avatar frames (crowns, shields, standard rings)",
      "Terminated visibility toggles (admin-only) with greyed layouts",
      "Direct email and phone quick-link buttons"
    ],
    tech: ["DirectoryController", "isPrivileged Props", "User Model"],
    mockType: "directory"
  },
  {
    id: "executive",
    num: "2.13",
    title: "Executive Dashboard & Super Admin Controls",
    tags: ["Admin", "Security", "Backend"],
    description: "A privileged command center offering company statistics, role modifiers, system-wide configuration, and audit logs.",
    features: [
      "Company counts overview dashboard (Employees, Users, Leaves, Overtime)",
      "Granular user role and manager assignment controls",
      "System config toggles and environmental setting displays",
      "Auditing timelines tracking system-wide activity details"
    ],
    tech: ["EnsureRole Middleware", "SystemConfigController", "AuditLogController", "spatie/laravel-activitylog"],
    mockType: "executive"
  },
  {
    id: "employee-crud",
    num: "2.14",
    title: "Employee Management (Admin CRUD)",
    tags: ["Admin", "Backend"],
    description: "An HR admin dashboard to register, update, terminate, and delete employee files through validation steps.",
    features: [
      "Comprehensive employee onboarding forms with validation checks",
      "Employee file updates (personal info, 2FA states, core status)",
      "Guided wizard overlays and modal confirmation overlays",
      "Soft-deletes and termination record preservation rules"
    ],
    tech: ["EmployeeManagementController", "CreateEmployee.vue", "CreateEmployeeModal.vue"],
    mockType: "crud"
  },
  {
    id: "layout-nav",
    num: "2.15",
    title: "Application Layout & Collapsible Navigation",
    tags: ["Frontend"],
    description: "The global authenticated app shell providing sidebar navigations, instant shortcuts, and global notifications.",
    features: [
      "Collapsible sidebar linking brand assets and sites",
      "Universal module search to navigate views quickly",
      "Role-filtered menu generation with expandable sub-links",
      "Global toast stack triggers for action confirmations",
      "Fully responsive responsive wrapper layouts"
    ],
    tech: ["ToastContainer.vue", "SidebarNav.vue", "Inertia Layouts"],
    mockType: "layout"
  }
];

const journalWeeks = [
  {
    week: "Week 1",
    dates: "Apr 27 – May 01",
    summary: "Onboarding and orientation. Local environment setup (PHP, MySQL, Composer, Node.js). Cloning the BeeConnected repository and running initial migrations.",
    learnings: "Local stack configuration, git workflows, repository onboarding."
  },
  {
    week: "Week 2",
    dates: "May 04 – May 08",
    summary: "Studying the existing codebase architecture. Analyzing routes/web.php, middleware structure, and Inertia rendering flow. Building the custom login controller with work_email mapping.",
    learnings: "Inertia routing, custom authentication fields mapping, Laravel controllers."
  },
  {
    week: "Week 3",
    dates: "May 11 – May 15",
    summary: "Researching TOTP algorithms and the spomky-labs/otphp library. Designing the TwoFactorCode model and migration. Beginning 2FA setup page development.",
    learnings: "TOTP encryption theories, database migrations design, Eloquent model scoping."
  },
  {
    week: "Week 4",
    dates: "May 18 – May 22",
    summary: "Completing the 2FA Setup wizard: QR code generation with qrcode.vue, backup secret key display, 6-digit verification input. Implementing enable/disable/regenerate actions.",
    learnings: "Vue 3 reactive setups, QR rendering pipelines, state toggle actions."
  },
  {
    week: "Week 5",
    dates: "May 25 – May 29",
    summary: "Developing Require2FA middleware. Building password reset flow branching (TOTP vs OTP). Integrating 2FA enforcement into all authenticated route groups.",
    learnings: "Middleware interception logic, authentication state routing."
  },
  {
    week: "Week 6",
    dates: "Jun 01 – Jun 05",
    summary: "Designing the Emergency Contacts database schema. Creating Eloquent model, migration, and form request validation classes. Building the ValidatesPhilippinePhones trait.",
    learnings: "Form requests validation layers, PHP traits implementation, regex validation rules."
  },
  {
    week: "Week 7",
    dates: "Jun 08 – Jun 12",
    summary: "Completing emergency contacts CRUD (employee and admin sides). Implementing Toast.vue notification component. Developing the admin emergency contacts management view.",
    learnings: "Full CRUD cycles, global UI component states, admin scope validation."
  },
  {
    week: "Week 8",
    dates: "Jun 15 – Jun 19",
    summary: "Designing the time_logs table schema. Building TimeLogController and TimeLogRequest validation. Implementing clock-in/out backend logic with server-set timestamps.",
    learnings: "Timestamp synchronization, database integrity, controller route mappings."
  },
  {
    week: "Week 9",
    dates: "Jun 22 – Jun 26",
    summary: "Developing WebcamCapture.vue with HTML5 MediaDevices API. Building TimeClockWidget.vue and TimeClockModal.vue. Testing camera constraints across browsers.",
    learnings: "HTML5 camera access, media stream handling, browser support checks."
  },
  {
    week: "Week 10",
    dates: "Jun 29 – Jul 03",
    summary: "Integrating secure private storage for time log photos. Building admin time log management (list, detail, edit, delete, CSV export, statistics). Implementing leave management and overtime request modules.",
    learnings: "Laravel storage system, security guidelines, CSV data streams, N+1 query troubleshooting."
  },
  {
    week: "Week 11",
    dates: "Jul 06 – Jul 10",
    summary: "Developing the Payroll dashboard and Payslip module (admin CRUD, earnings/deductions, mark-paid, PDF export). Building SSO integration with custom Socialite provider and SSO app management.",
    learnings: "Payroll math validation, DOM-to-PDF drivers, custom OAuth2 drivers, pivot relations."
  },
  {
    week: "Week 12",
    dates: "Jul 13 – Jul 17",
    summary: "Implementing the Hiring module (job listings CRUD, applications pipeline, resume viewer) and public Careers page. Building the Employee Directory with role-based avatars. Developing the Executive Dashboard and controls.",
    learnings: "Kanban pipeline designs, public Guest routers, role asset logic, admin dashboards."
  },
  {
    week: "Week 13",
    dates: "Jul 20 – Jul 24",
    summary: "System integration testing and edge case resolution. Writing technical documentation (architecture reviews, deployment checklists, turnover notes). Final code review and internship handback.",
    learnings: "E2E verification, QA processes, Technical documentation, handover procedures."
  }
];

const tagsList = ["All", "Backend", "Frontend", "Security", "Admin", "Recruitment"];
---

<BaseLayout title="Practicum Narrative Report — Software Engineering">
  <Nav />
  
  <main class="w-full">
    <!-- Hero Section -->
    <header class="border-b border-border p-8 sm:p-12 lg:p-16 flex flex-col justify-center items-start text-left min-h-[40vh] bg-bg-secondary/10">
      <div class="reveal font-mono text-[11px] text-text-muted tracking-widest mb-6 flex items-center gap-2">
        <span class="text-text-primary">02.</span> PRACTICUM
      </div>
      <h1 class="reveal reveal-delay-1 text-4xl sm:text-5xl lg:text-6xl font-black uppercase tracking-tighter leading-[0.95] max-w-4xl mb-6">
        Internship Narrative Report
      </h1>
      <p class="reveal reveal-delay-2 text-base text-text-secondary max-w-2xl leading-relaxed font-light">
        A comprehensive review of the 480-hour Software Engineering Practicum at PurpleBug Inc., developing the BeeConnected Human Resource Information System (HRIS).
      </p>
    </header>

    <!-- Key Metrics Dashboard Grid -->
    <section class="border-b border-border grid grid-cols-2 md:grid-cols-5 divide-y md:divide-y-0 md:divide-x divide-border bg-bg-secondary/5 font-mono text-[11px]">
      <div class="p-6 flex flex-col gap-1.5 justify-center">
        <span class="text-text-muted uppercase tracking-wider">Intern</span>
        <span class="text-text-primary font-bold text-xs uppercase">[Your Name]</span>
      </div>
      <div class="p-6 flex flex-col gap-1.5 justify-center">
        <span class="text-text-muted uppercase tracking-wider">Company</span>
        <span class="text-text-primary font-bold text-xs">PurpleBug Inc.</span>
      </div>
      <div class="p-6 flex flex-col gap-1.5 justify-center">
        <span class="text-text-muted uppercase tracking-wider">Duration</span>
        <span class="text-text-primary font-bold text-xs">Apr 27 – Jul 24, 2026</span>
      </div>
      <div class="p-6 flex flex-col gap-1.5 justify-center">
        <span class="text-text-muted uppercase tracking-wider">Hours Rendered</span>
        <span class="text-text-primary font-bold text-xs text-accent">480 / 480 Hours</span>
      </div>
      <div class="p-6 flex flex-col gap-1.5 justify-center col-span-2 md:col-span-1">
        <span class="text-text-muted uppercase tracking-wider">Core Tech</span>
        <span class="text-text-primary font-bold text-[10px] truncate">Laravel 12, Vue 3, Tailwind 4</span>
      </div>
    </section>

    <!-- Main Content Layout -->
    <section class="grid md:grid-cols-12 w-full min-h-screen relative">
      <!-- Sticky Sidebar Table of Contents -->
      <aside class="md:col-span-3 border-b md:border-b-0 md:border-r border-border p-6 lg:p-8 md:sticky md:top-[57px] md:h-[calc(100vh-57px)] overflow-y-auto">
        <div class="flex flex-col gap-8 h-full justify-between">
          <div class="flex flex-col gap-6">
            <span class="font-mono text-[10px] text-text-muted tracking-widest uppercase">Navigation</span>
            <ul class="flex flex-row md:flex-col gap-4 overflow-x-auto md:overflow-x-visible pb-2 md:pb-0 font-mono text-[11px] tracking-wider uppercase">
              <li>
                <a href="#overview" class="toc-link text-text-secondary hover:text-text-primary transition-colors flex items-center gap-2 active">
                  <span class="text-text-muted">1.0</span> Overview
                </a>
              </li>
              <li>
                <a href="#outputs" class="toc-link text-text-secondary hover:text-text-primary transition-colors flex items-center gap-2">
                  <span class="text-text-muted">2.0</span> Output Modules
                </a>
              </li>
              <li>
                <a href="#synthesis" class="toc-link text-text-secondary hover:text-text-primary transition-colors flex items-center gap-2">
                  <span class="text-text-muted">3.0</span> Synthesis
                </a>
              </li>
              <li>
                <a href="#journal" class="toc-link text-text-secondary hover:text-text-primary transition-colors flex items-center gap-2">
                  <span class="text-text-muted">4.0</span> Weekly Journal
                </a>
              </li>
            </ul>
          </div>

          <div class="hidden md:flex flex-col gap-3 p-4 border border-border bg-bg-secondary/40 font-mono text-[10px] leading-relaxed">
            <span class="text-text-primary font-bold">BeeConnected HRIS</span>
            <p class="text-text-muted">Developed to streamline enterprise core operations from authentication and biometric verifications to payroll management and hiring pipelines.</p>
          </div>
        </div>
      </aside>

      <!-- Scrollable Content -->
      <div class="md:col-span-9 p-6 sm:p-12 lg:p-16 space-y-24 overflow-x-hidden">
        
        <!-- SECTION 1.0 OVERVIEW -->
        <article id="overview" class="space-y-12 scroll-mt-24">
          <div class="border-b border-border pb-6 flex items-baseline justify-between">
            <h2 class="text-2xl sm:text-3xl font-black uppercase tracking-tight">1.0 Overview of Practicum</h2>
            <span class="font-mono text-xs text-text-muted">PurpleBug Inc.</span>
          </div>

          <div class="grid md:grid-cols-2 gap-8 text-sm leading-relaxed font-light text-text-secondary">
            <div class="space-y-4">
              <h3 class="font-mono text-xs font-bold text-text-primary uppercase tracking-wider">Company Background</h3>
              <p>
                <strong>PurpleBug Inc.</strong> is a technology-first, data-driven marketing technology company founded in 2011. Headquartered in Makati City, Philippines, PurpleBug specializes in providing a combined solution of strategy and technology to help businesses integrate their sales, marketing, customer service, and IT operations.
              </p>
              <p>
                Beyond digital marketing and SEO services, PurpleBug operates as an enterprise software solutions provider, developing proprietary platforms like Smicos (chatbot), DocuMeant (DMS), Zagidee (PM), OnTarget (Sales), and <strong>BeeConnected</strong> (HRIS).
              </p>
            </div>
            <div class="space-y-4">
              <h3 class="font-mono text-xs font-bold text-text-primary uppercase tracking-wider font-semibold">Assignments & Nature of Tasks</h3>
              <p>
                As a Software Engineering Intern, the primary assignment was to develop, enhance, and maintain core backend and frontend modules for the <strong>BeeConnected</strong> HRIS portal — an enterprise-grade employee management system built on <strong>Laravel 12, Vue 3, Inertia.js, and Tailwind CSS 4</strong>.
              </p>
              <p>
                Key responsibilities spanned 13 major feature areas including SSO Authentication, emergency contact phone validations, webcam-based photo check-ins, automated leave rules, payroll net pay algorithms, recruitment pipeline controls, and admin management CRUDs.
              </p>
            </div>
          </div>

          <!-- Product Grid Table -->
          <div class="border border-border">
            <div class="bg-bg-secondary/40 border-b border-border p-4 font-mono text-xs text-text-primary uppercase font-bold tracking-wider">
              PurpleBug Proprietary Products
            </div>
            <div class="grid divide-y divide-border font-mono text-[11px]">
              <div class="grid grid-cols-3 p-4 bg-bg-primary">
                <span class="text-text-primary font-bold">Smicos</span>
                <span class="col-span-2 text-text-secondary">AI-powered chatbot platform</span>
              </div>
              <div class="grid grid-cols-3 p-4 bg-bg-secondary/10">
                <span class="text-text-primary font-bold">DocuMeant</span>
                <span class="col-span-2 text-text-secondary">Document management system</span>
              </div>
              <div class="grid grid-cols-3 p-4 bg-bg-primary">
                <span class="text-text-primary font-bold">Zagidee</span>
                <span class="col-span-2 text-text-secondary">Project management tool</span>
              </div>
              <div class="grid grid-cols-3 p-4 bg-bg-secondary/10">
                <span class="text-text-primary font-bold">OnTarget</span>
                <span class="col-span-2 text-text-secondary">Sales performance tracking tool</span>
              </div>
              <div class="grid grid-cols-3 p-4 bg-bg-primary text-accent">
                <span class="font-bold">BeeConnected</span>
                <span class="col-span-2 text-text-secondary font-bold">Human Resource Information System (HRIS)</span>
              </div>
            </div>
          </div>

          <!-- Tech Stack Categories -->
          <div class="space-y-6">
            <h3 class="font-mono text-xs font-bold text-text-primary uppercase tracking-wider">Technology Stack Profile</h3>
            <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
              <div class="border border-border p-5 flex flex-col justify-between min-h-[140px] hover:border-text-muted transition-colors">
                <span class="font-mono text-[10px] text-text-muted uppercase">Backend</span>
                <div class="mt-4">
                  <span class="text-sm font-bold text-text-primary block">Laravel 12</span>
                  <span class="text-xs text-text-secondary font-mono">PHP 8.2+, MySQL</span>
                </div>
              </div>
              <div class="border border-border p-5 flex flex-col justify-between min-h-[140px] hover:border-text-muted transition-colors">
                <span class="font-mono text-[10px] text-text-muted uppercase">Frontend</span>
                <div class="mt-4">
                  <span class="text-sm font-bold text-text-primary block">Vue 3 / Inertia.js</span>
                  <span class="text-xs text-text-secondary font-mono">Vite 7, Ziggy Routing</span>
                </div>
              </div>
              <div class="border border-border p-5 flex flex-col justify-between min-h-[140px] hover:border-text-muted transition-colors">
                <span class="font-mono text-[10px] text-text-muted uppercase">Styling</span>
                <div class="mt-4">
                  <span class="text-sm font-bold text-text-primary block">Tailwind CSS 4</span>
                  <span class="text-xs text-text-secondary font-mono">Modern CSS compiler</span>
                </div>
              </div>
              <div class="border border-border p-5 flex flex-col justify-between min-h-[140px] hover:border-text-muted transition-colors">
                <span class="font-mono text-[10px] text-text-muted uppercase">Security & Libs</span>
                <div class="mt-4">
                  <span class="text-sm font-bold text-text-primary block">2FA, SSO OAuth2</span>
                  <span class="text-xs text-text-secondary font-mono">OTPHP, Activity Log</span>
                </div>
              </div>
            </div>
          </div>
        </article>

        <!-- SECTION 2.0 OUTPUT MODULES -->
        <article id="outputs" class="space-y-12 scroll-mt-24">
          <div class="border-b border-border pb-6 flex items-baseline justify-between">
            <h2 class="text-2xl sm:text-3xl font-black uppercase tracking-tight">2.0 Presentation of Output</h2>
            <span class="font-mono text-xs text-text-muted">15 System Modules</span>
          </div>

          <p class="text-sm leading-relaxed font-light text-text-secondary">
            Over the 480-hour practicum engagement, the following modules were designed, developed, and integrated into the BeeConnected HRIS enterprise platform.
          </p>

          <!-- Interactive Filters -->
          <div class="flex flex-wrap gap-2 py-2 border-y border-border/80 font-mono text-[10px] items-center">
            <span class="text-text-muted uppercase tracking-wider mr-2">Filter Modules:</span>
            {tagsList.map(tag => (
              <button
                class={`px-3 py-1.5 border border-border hover:border-text-primary hover:text-text-primary transition-all duration-200 cursor-pointer module-filter-btn uppercase ${tag === 'All' ? 'bg-text-primary text-bg-primary border-text-primary' : 'text-text-secondary bg-transparent'}`}
                data-tag={tag.toLowerCase()}
              >
                {tag}
              </button>
            ))}
          </div>

          <!-- Modules Container -->
          <div class="grid gap-12" id="modules-list">
