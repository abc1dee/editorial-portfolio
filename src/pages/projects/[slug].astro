---
import '../../styles/global.css';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
const { title, description, tags, role, challenge, architecture, keyDecisions, results, liveUrl, githubUrl, thumbnail, gallery } = project.data;

const isMobile = tags && tags.some(t =>
  t.toLowerCase().includes('react native') ||
  t.toLowerCase().includes('mobile') ||
  t.toLowerCase().includes('expo') ||
  t.toLowerCase().includes('ios') ||
  t.toLowerCase().includes('android')
);
---

<BaseLayout title={`${title} — Case Study`} description={description}>
  <Nav />
  <main class="pt-24 border-b border-border">
    <!-- Case Study Hero -->
    <section class="px-6 py-16 border-b border-border">
      <div class="max-w-4xl mx-auto">
        <a href="/#projects" class="reveal group inline-flex items-center gap-1.5 font-mono text-[11px] tracking-widest text-text-secondary hover:text-text-primary transition-colors mb-8">
          <svg class="w-3.5 h-3.5 transition-transform duration-300 group-hover:-translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
          </svg>
          <span class="underline-slide">Back to all projects</span>
        </a>

        <div class="reveal">
          <h1 class="text-4xl sm:text-5xl lg:text-6xl font-black uppercase tracking-tighter mb-4">{title}</h1>
          <p class="text-lg text-text-secondary leading-relaxed mb-6 font-light">{description}</p>

          <div class="flex flex-wrap items-center gap-2 mb-8">
            <span class="px-3 py-1.5 text-[10px] font-mono uppercase tracking-wider border border-border bg-text-primary text-bg-primary">
              {role}
            </span>
            {tags.map((tag) => (
              <span class="px-2.5 py-1.5 text-[9px] font-mono uppercase tracking-wider bg-bg-secondary/40 text-text-secondary border border-border">
                {tag}
              </span>
            ))}
          </div>

          <!-- Action links -->
          <div class="flex gap-4">
            {liveUrl && (
              <a href={liveUrl} target="_blank" rel="noopener noreferrer" class="px-5 py-3 font-mono text-xs tracking-widest uppercase border border-border bg-text-primary text-bg-primary hover:bg-bg-primary hover:text-text-primary transition-all duration-300 focus-ring">
                [ Live Demo ↗ ]
              </a>
            )}
            {githubUrl && (
              <a href={githubUrl} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 px-5 py-3 font-mono text-xs tracking-widest uppercase border border-border bg-bg-primary text-text-primary hover:bg-text-primary hover:text-bg-primary transition-all duration-300 focus-ring">
                <svg class="w-3.5 h-3.5 fill-current" viewBox="0 0 24 24">
                  <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
                </svg>
                [ Source Code ↗ ]
              </a>
            )}
          </div>
        </div>
      </div>
    </section>

    <!-- Hero Image / Gallery Slot -->
    <section class="px-6 mb-16">
      <div class="max-w-5xl mx-auto">
        {gallery && gallery.length > 0 ? (
          /* Multi-image Gallery Carousel */
          isMobile ? (
            /* Mobile Phone Mockup Carousel */
            <div class="reveal flex flex-col items-center justify-center gap-6 select-none">
              <div class="flex items-center justify-center gap-4 sm:gap-8 w-full max-w-xl">
                <!-- Prev Button -->
                <button id="hero-prev" class="w-10 h-10 border border-border flex items-center justify-center text-text-secondary hover:text-text-primary hover:border-text-primary transition-all duration-200 cursor-pointer bg-bg-secondary/20 focus-ring" aria-label="Previous image">
                  <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5" />
                  </svg>
                </button>

                <!-- Phone Mockup Container -->
                <div class="relative w-[260px] sm:w-[290px] aspect-[9/19.5] border-[8px] border-border bg-bg-card rounded-[36px] shadow-2xl overflow-hidden flex flex-col justify-between">
                  <!-- Notch -->
                  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-32 h-5 bg-border rounded-b-xl z-20 flex items-center justify-center">
                    <div class="w-10 h-1 bg-bg-primary rounded-full mb-1"></div>
                  </div>

                  <!-- Slides -->
                  <div class="relative flex-grow w-full h-full overflow-hidden bg-black">
                    {gallery.map((item, idx) => (
                      <div
                        class={`hero-slide absolute inset-0 transition-opacity duration-500 flex items-center justify-center ${idx === 0 ? 'opacity-100 z-10' : 'opacity-0 z-0'}`}
                        data-index={idx}
                      >
                        <img src={item.path} alt={item.label} class="w-full h-full object-cover" />
                        <div class="absolute bottom-0 inset-x-0 bg-gradient-to-t from-black/90 via-black/40 to-transparent p-4 pt-12 text-center z-20">
                          <span class="font-mono text-[9px] text-text-secondary/80 uppercase tracking-widest block">Slide {idx + 1} of {gallery.length}</span>
                          <span class="text-xs font-bold text-white uppercase mt-1 block">{item.label}</span>
                        </div>
                      </div>
                    ))}
                  </div>
                </div>

                <!-- Next Button -->
                <button id="hero-next" class="w-10 h-10 border border-border flex items-center justify-center text-text-secondary hover:text-text-primary hover:border-text-primary transition-all duration-200 cursor-pointer bg-bg-secondary/20 focus-ring" aria-label="Next image">
                  <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
                  </svg>
                </button>
              </div>
            </div>
          ) : (
            /* Desktop Browser Mockup Carousel */
            <div class="reveal flex flex-col items-center justify-center gap-6 select-none">
              <div class="flex items-center justify-center gap-4 sm:gap-6 w-full">
                <!-- Prev Button -->
                <button id="hero-prev" class="w-10 h-10 border border-border flex items-center justify-center text-text-secondary hover:text-text-primary hover:border-text-primary transition-all duration-200 cursor-pointer bg-bg-secondary/20 focus-ring" aria-label="Previous image">
                  <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5" />
                  </svg>
                </button>

                <!-- Browser Mockup Container -->
                <div class="flex-grow w-full border border-border bg-bg-card font-mono text-[11px] text-text-secondary select-none overflow-hidden relative shadow-2xl">
                  <!-- Browser Header -->
                  <div class="flex items-center justify-between px-4 py-2.5 bg-bg-secondary/90 border-b border-border">
                    <div class="flex items-center gap-1.5">
                      <span class="w-2.5 h-2.5 border border-border bg-transparent"></span>
                      <span class="w-2.5 h-2.5 border border-border bg-transparent"></span>
                      <span class="w-2.5 h-2.5 border border-border bg-transparent"></span>
                    </div>
                    <span class="text-[9px] text-text-muted font-bold tracking-wider uppercase">Project Live Preview</span>
                    <div class="w-6"></div>
                  </div>

                  <!-- Slides -->
                  <div class="relative aspect-video overflow-hidden">
                    {gallery.map((item, idx) => (
                      <div
                        class={`hero-slide absolute inset-0 transition-opacity duration-500 flex items-center justify-center ${idx === 0 ? 'opacity-100 z-10' : 'opacity-0 z-0'}`}
                        data-index={idx}
                      >
                        <img src={item.path} alt={item.label} class="w-full h-full object-cover" />
                        <div class="absolute bottom-0 inset-x-0 bg-gradient-to-t from-black/80 via-black/40 to-transparent p-4 pt-12 text-center z-20">
                          <span class="font-mono text-[9px] text-text-secondary/80 uppercase tracking-widest block">Slide {idx + 1} of {gallery.length}</span>
                          <span class="text-xs font-bold text-white uppercase mt-1 block">{item.label}</span>
                        </div>
                      </div>
                    ))}
                  </div>
                </div>

                <!-- Next Button -->
                <button id="hero-next" class="w-10 h-10 border border-border flex items-center justify-center text-text-secondary hover:text-text-primary hover:border-text-primary transition-all duration-200 cursor-pointer bg-bg-secondary/20 focus-ring" aria-label="Next image">
                  <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
                  </svg>
                </button>
              </div>
            </div>
          )
        ) : thumbnail ? (
          /* Single Image Fallback */
          isMobile ? (
            /* Single Image Mobile Phone Mockup */
            <div class="reveal flex flex-col items-center justify-center">
              <div class="relative w-[260px] sm:w-[290px] aspect-[9/19.5] border-[8px] border-border bg-bg-card rounded-[36px] shadow-2xl overflow-hidden group">
                <!-- Notch -->
                <div class="absolute top-0 left-1/2 -translate-x-1/2 w-32 h-5 bg-border rounded-b-xl z-20 flex items-center justify-center">
                  <div class="w-10 h-1 bg-bg-primary rounded-full mb-1"></div>
                </div>
                <img src={thumbnail} alt={`${title} thumbnail`} class="w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-105" />
              </div>
            </div>
          ) : (
            /* Single Image Desktop aspect-video */
            <div class="reveal aspect-video overflow-hidden bg-bg-card border border-border group">
              <img src={thumbnail} alt={`${title} hero image`} class="w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-105" />
            </div>
          )
        ) : (
          /* Generic Empty State */
          <div class="reveal aspect-video overflow-hidden bg-bg-card border border-border flex items-center justify-center bg-bg-secondary/20">
            <div class="text-center">
              <div class="w-16 h-16 mx-auto mb-4 border border-border flex items-center justify-center">
                <svg class="w-8 h-8 text-text-muted" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909M3.75 21h16.5a1.5 1.5 0 001.5-1.5V6a1.5 1.5 0 00-1.5-1.5H3.75A1.5 1.5 0 002.25 6v13.5A1.5 1.5 0 003.75 21z" />
                </svg>
              </div>
              <p class="text-xs font-mono uppercase tracking-wider text-text-muted">Project hero image slot</p>
            </div>
          </div>
        )}
      </div>
    </section>

    <!-- Challenge + Architecture -->
    <section class="px-6 mb-16">
      <div class="max-w-4xl mx-auto grid md:grid-cols-2 gap-8">
        {challenge && (
          <div class="reveal border border-border bg-bg-card p-8">
            <h2 class="font-mono text-xs font-bold uppercase tracking-widest mb-4 flex items-center gap-2">
              <span class="w-6 h-6 border border-border flex items-center justify-center">
                <svg class="w-3.5 h-3.5 text-text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126z" />
                </svg>
              </span>
              The Challenge
            </h2>
            <p class="text-text-secondary text-xs leading-relaxed font-light">{challenge}</p>
          </div>
        )}
        {architecture && (
          <div class="reveal reveal-delay-1 border border-border bg-bg-card p-8">
            <h2 class="font-mono text-xs font-bold uppercase tracking-widest mb-4 flex items-center gap-2">
              <span class="w-6 h-6 border border-border flex items-center justify-center">
                <svg class="w-3.5 h-3.5 text-text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M6.429 9.75L2.25 12l4.179 2.25m0-4.5l5.571 3 5.571-3m-11.142 0L2.25 7.5 12 2.25l9.75 5.25-4.179 2.25m0 0L12 12.75 6.429 9.75m11.142 0l4.179 2.25L12 17.25 2.25 12l4.179-2.25" />
                </svg>
              </span>
              Architecture
            </h2>
            <p class="text-text-secondary text-xs leading-relaxed font-light">{architecture}</p>
          </div>
        )}
      </div>
    </section>

    <!-- Key Decisions -->
    {keyDecisions && keyDecisions.length > 0 && (
      <section class="px-6 mb-16">
        <div class="max-w-4xl mx-auto border-t border-border pt-12">
          <h2 class="reveal font-mono text-xs font-bold uppercase tracking-widest mb-6">[ // KEY_DECISIONS ]</h2>
          <div class="space-y-4">
            {keyDecisions.map((decision, i) => (
              <div class={`reveal reveal-delay-${Math.min(i + 1, 4)} flex gap-4 p-5 border border-border bg-bg-card`}>
                <span class="flex-shrink-0 w-6 h-6 border border-border flex items-center justify-center text-xs font-mono font-bold text-text-primary bg-bg-secondary">
                  {String(i + 1).padStart(2, '0')}
                </span>
                <p class="text-text-secondary text-xs leading-relaxed font-light">{decision}</p>
              </div>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- Results -->
    {results && results.length > 0 && (
      <section class="px-6 mb-16">
        <div class="max-w-4xl mx-auto border-t border-border pt-12">
          <h2 class="reveal font-mono text-xs font-bold uppercase tracking-widest mb-6">[ // METRICS_AND_RESULTS ]</h2>
          <div class="grid sm:grid-cols-3 gap-4">
            {results.map((result, i) => (
              <div class={`reveal reveal-delay-${Math.min(i + 1, 4)} p-6 border border-border bg-bg-card text-center flex flex-col justify-center min-h-[100px]`}>
                <p class="text-xs font-mono uppercase tracking-wider text-text-secondary font-light">{result}</p>
              </div>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- Markdown Body -->
    <section class="px-6 mb-16">
      <div class="max-w-4xl mx-auto prose prose-invert prose-sm max-w-none border-t border-border pt-12">
        <Content />
      </div>
    </section>

    <!-- Screenshots Gallery -->
    {gallery && gallery.length > 0 && (
      <section class="px-6 mb-16">
        <div class="max-w-4xl mx-auto border-t border-border pt-12">
          <h2 class="reveal font-mono text-xs font-bold uppercase tracking-widest mb-6">[ // SYSTEM_INTERFACE_SCREENSHOTS ]</h2>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            {gallery.map((item, i) => (
              <div
                class={`reveal reveal-delay-${Math.min(i + 1, 4)} border border-border bg-bg-card overflow-hidden group cursor-pointer gallery-card`}
                data-path={item.path}
                data-label={item.label}
                data-fig={`Figure ${String(i + 1).padStart(2, '0')}`}
                data-description={item.description || ''}
              >
                <div class="aspect-video overflow-hidden border-b border-border bg-bg-secondary/10">
                  <img
                    src={item.path}
                    alt={item.label}
                    class="w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-105"
                    loading="lazy"
                  />
                </div>
                <div class="p-4 bg-bg-secondary/20">
                  <span class="font-mono text-[9px] text-text-muted uppercase tracking-wider block">Figure {String(i + 1).padStart(2, '0')}</span>
                  <span class="text-xs font-bold text-text-secondary uppercase">{item.label}</span>
                </div>
              </div>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- Next Project CTA -->
    <section class="px-6 pb-16">
      <div class="max-w-4xl mx-auto text-center border-t border-border pt-12">
        <a href="/#projects" class="reveal group inline-flex items-center gap-1.5 font-mono text-[11px] tracking-widest text-text-secondary hover:text-text-primary transition-colors focus-ring">
          <svg class="w-3.5 h-3.5 transition-transform duration-300 group-hover:-translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
          </svg>
          <span class="underline-slide">View all projects</span>
        </a>
      </div>
    </section>
  </main>
  
  <!-- Popup Modal for Screenshots -->
  <div id="screenshot-modal" class="fixed inset-0 z-50 flex items-center justify-center bg-black/75 backdrop-blur-sm opacity-0 pointer-events-none transition-all duration-300 p-4">
    <!-- Modal Card Popup -->
    <div class={`relative bg-bg-card border border-border flex flex-col w-full shadow-2xl p-6 md:p-8 ${isMobile ? 'max-w-sm' : 'max-w-4xl'}`}>
      
      <!-- Close Button inside card -->
      <button id="modal-close" class="absolute top-4 right-4 w-8 h-8 border border-border flex items-center justify-center text-text-secondary hover:text-text-primary hover:border-text-primary transition-all duration-200 cursor-pointer bg-bg-secondary/40 font-mono text-[10px] focus-ring z-30" aria-label="Close modal">
        ✕
      </button>

      <!-- Modal Content -->
      <div class="flex flex-col gap-4">
        <!-- Uncropped Image Container -->
        <div class="border border-border bg-bg-secondary/10 flex items-center justify-center p-1 overflow-hidden">
          <img id="modal-img" class="max-w-full max-h-[60vh] object-contain" src="" alt="" />
        </div>
        
        <!-- Typography: Figure, Title, Description -->
        <div class="text-left mt-2 border-t border-border/50 pt-4">
          <span id="modal-fig" class="font-mono text-[9px] text-text-muted uppercase tracking-wider block"></span>
          <h3 id="modal-title" class="text-sm font-bold text-text-primary uppercase mt-1"></h3>
          <p id="modal-desc" class="text-text-secondary font-light text-[11px] leading-relaxed mt-2"></p>
        </div>
      </div>
    </div>
  </div>

  <Footer />
</BaseLayout>

<script>
  // Hero Carousel Logic
  const slides = document.querySelectorAll('.hero-slide');
  const prevBtn = document.getElementById('hero-prev');
  const nextBtn = document.getElementById('hero-next');

  if (slides.length > 1 && prevBtn && nextBtn) {
    let currentIdx = 0;
    function updateSlides(newIdx: number) {
      slides[currentIdx].classList.remove('opacity-100', 'z-10');
      slides[currentIdx].classList.add('opacity-0', 'z-0');
      currentIdx = (newIdx + slides.length) % slides.length;
      slides[currentIdx].classList.remove('opacity-0', 'z-0');
      slides[currentIdx].classList.add('opacity-100', 'z-10');
    }
    prevBtn.addEventListener('click', () => updateSlides(currentIdx - 1));
    nextBtn.addEventListener('click', () => updateSlides(currentIdx + 1));
  }

  // Modal Logic
  const modal = document.getElementById('screenshot-modal');
  const modalImg = document.getElementById('modal-img');
  const modalFig = document.getElementById('modal-fig');
  const modalTitle = document.getElementById('modal-title');
  const modalDesc = document.getElementById('modal-desc');
  const modalClose = document.getElementById('modal-close');
  const galleryCards = document.querySelectorAll('.gallery-card');

  if (modal && modalImg && modalFig && modalTitle && modalDesc && modalClose) {
    galleryCards.forEach(card => {
      card.addEventListener('click', () => {
        const path = card.getAttribute('data-path') || '';
        const label = card.getAttribute('data-label') || '';
        const fig = card.getAttribute('data-fig') || '';
        const desc = card.getAttribute('data-description') || '';

        modalImg.setAttribute('src', path);
        modalImg.setAttribute('alt', label);
        modalFig.textContent = fig;
        modalTitle.textContent = label;
        modalDesc.textContent = desc;

        modal.classList.remove('opacity-0', 'pointer-events-none');
        document.body.style.overflow = 'hidden'; // Lock background scroll
      });
    });

    const closeModal = () => {
      modal.classList.add('opacity-0', 'pointer-events-none');
      document.body.style.overflow = ''; // Unlock scroll
      setTimeout(() => {
        modalImg.setAttribute('src', '');
      }, 300);
    };

    modalClose.addEventListener('click', closeModal);
    modal.addEventListener('click', (e) => {
      if (e.target === modal) {
        closeModal();
      }
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        closeModal();
      }
    });
  }
</script>
