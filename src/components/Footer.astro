---
/* Footer.astro — Footer with final CTA per SKILL.md CTA Placement */
const currentYear = new Date().getFullYear();
---

<footer class="border-t border-border py-12 px-6">
  <div class="max-w-6xl mx-auto">
    <!-- Final CTA -->
    <div class="text-center mb-10">
      <p class="text-text-secondary text-sm mb-3">Interested in working together?</p>
      <a
        href="#contact"
        id="footer-cta"
        class="inline-flex items-center gap-2 text-accent font-semibold hover:text-accent-hover transition-colors focus-ring"
      >
        Get in touch
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 19.5l15-15m0 0H8.25m11.25 0v11.25" />
        </svg>
      </a>
    </div>

    <!-- Bottom row -->
    <div class="flex flex-col sm:flex-row items-center justify-between gap-4 text-xs text-text-muted">
      <p>© {currentYear} Deo. Built with Astro.</p>
      <div class="flex items-center gap-4">
        <a href="https://github.com/abc1dee" target="_blank" rel="noopener noreferrer" class="hover:text-accent transition-colors">GitHub</a>
        <a href="https://www.linkedin.com/in/clarence-abcdee-glorioso-82b6951a1" target="_blank" rel="noopener noreferrer" class="hover:text-accent transition-colors">LinkedIn</a>
      </div>
    </div>
  </div>
</footer>
