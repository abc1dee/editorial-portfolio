---
/* ThemeToggle.astro — Dark/Light mode island, supports multiple instances on the same page */
---

<button
  class="theme-toggle p-2 rounded-lg text-text-secondary hover:text-accent hover:bg-bg-tertiary transition-colors focus-ring cursor-pointer"
  aria-label="Toggle dark/light mode"
>
  <!-- Sun icon (shown in dark mode) -->
  <svg class="sun-icon w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
    <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z" />
  </svg>
  <!-- Moon icon (shown in light mode) -->
  <svg class="moon-icon w-5 h-5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
    <path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.718 9.718 0 0118 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 003 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 009.002-5.998z" />
  </svg>
</button>

<script>
  const html = document.documentElement;

  function updateIcons(dark: boolean) {
    document.querySelectorAll(".sun-icon").forEach(icon => icon.classList.toggle("hidden", !dark));
    document.querySelectorAll(".moon-icon").forEach(icon => icon.classList.toggle("hidden", dark));
  }

  function applyTheme(dark: boolean) {
    html.classList.toggle("dark", dark);
    updateIcons(dark);
    localStorage.setItem("theme", dark ? "dark" : "light");
  }

  // Check saved preference or default to dark
  const saved = localStorage.getItem("theme");
  const isDark = saved ? saved === "dark" : true;
  applyTheme(isDark);

  // Bind all theme toggles
  document.querySelectorAll(".theme-toggle").forEach((toggle) => {
    toggle.addEventListener("click", () => {
      const nowDark = html.classList.contains("dark");
      applyTheme(!nowDark);
    });
  });
</script>
