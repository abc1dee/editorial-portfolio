---
/* Hero.astro — Bold digital editorial grid hero section */
---

<section
  id="hero"
  class="relative min-h-[90vh] flex flex-col border-b border-border overflow-hidden"
>
  <div class="grid md:grid-cols-12 w-full flex-grow">
    <!-- Left Column: Typographic Editorial Section -->
    <div class="md:col-span-7 p-8 sm:p-12 lg:p-16 flex flex-col justify-center items-start text-left">
      <!-- Index Label -->
      <div class="reveal font-mono text-[11px] text-text-muted tracking-widest mb-6 flex items-center gap-2">
        <span class="text-text-primary">01.</span> INTRO
      </div>

      <!-- Oversized Display Headline -->
      <h1 class="reveal reveal-delay-1 text-5xl sm:text-7xl lg:text-[80px] font-black tracking-tighter leading-[0.9] uppercase mb-8">
        Full-Stack<br/>
        & Systems<br/>
        Engineer
      </h1>

      <!-- Differentiator -->
      <p class="reveal reveal-delay-2 text-base sm:text-lg text-text-secondary max-w-xl mb-10 leading-relaxed font-light">
        I design and build high-performance systems — from interactive client applications to low-latency backends and distributed APIs.
      </p>

      <!-- Dual CTA Buttons -->
      <div class="reveal reveal-delay-3 flex flex-wrap gap-4 w-full sm:w-auto">
        <a
          href="#projects"
          class="px-6 py-3.5 font-mono text-xs tracking-widest uppercase border border-border bg-text-primary text-bg-primary hover:bg-bg-primary hover:text-text-primary transition-all duration-300 focus-ring"
        >
          [ View Case Studies ]
        </a>
        <a
          href="#contact"
          class="px-6 py-3.5 font-mono text-xs tracking-widest uppercase border border-border bg-bg-primary text-text-primary hover:bg-text-primary hover:text-bg-primary transition-all duration-300 focus-ring"
        >
          [ Get in Touch ]
        </a>
      </div>
    </div>

    <!-- Right Column: Boxy Interactive Terminal Widget -->
    <div class="md:col-span-5 border-t md:border-t-0 md:border-l border-border p-8 sm:p-12 lg:p-16 flex flex-col justify-center bg-bg-secondary/20">
      <div class="reveal reveal-delay-2 w-full max-w-md mx-auto">
        <!-- Status indicator -->
        <div class="flex items-center gap-2 mb-6 text-xs text-text-secondary">
          <span class="relative flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full bg-text-primary opacity-75"></span>
            <span class="relative inline-flex h-2 w-2 bg-text-primary"></span>
          </span>
          ACTIVE STATUS: OPEN FOR OFFERS
        </div>

        <!-- Flat Boxy Terminal Window carrying the Photo -->
        <div class="border border-border bg-bg-card font-mono text-[11px] text-text-secondary select-none overflow-hidden relative">
          <!-- Terminal Header -->
          <div class="flex items-center justify-between px-4 py-3 bg-bg-secondary border-b border-border">
            <div class="flex items-center gap-1">
              <span class="w-2.5 h-2.5 border border-border bg-transparent"></span>
              <span class="w-2.5 h-2.5 border border-border bg-transparent"></span>
              <span class="w-2.5 h-2.5 border border-border bg-transparent"></span>
            </div>
            <span class="text-[10px] text-text-muted font-bold tracking-wider">SYSTEM_MONITOR.SH</span>
            <div class="w-8"></div>
          </div>

          <!-- Image Area / Scanner HUD -->
          <div class="relative w-full aspect-[4/3] bg-bg-secondary/20 overflow-hidden group">
            <!-- Profile image (User can place avatar.jpg inside public/) -->
            <img
              src="/avatar.jpg"
              alt="Developer Profile Photo"
              class="w-full h-full object-cover filter grayscale contrast-125 brightness-90 group-hover:grayscale-0 group-hover:contrast-100 group-hover:brightness-100 transition-all duration-700"
              onerror="this.style.display='none'"
            />
            
            <!-- Terminal HUD Grid & Crosshairs -->
            <svg viewBox="0 0 100 100" class="absolute inset-0 w-full h-full pointer-events-none" xmlns="http://www.w3.org/2000/svg">
              <!-- Corner crop marks -->
              <path d="M 8 15 L 8 8 L 15 8" fill="none" stroke="var(--border-color)" stroke-width="0.8" opacity="0.6" />
              <path d="M 92 15 L 92 8 L 85 8" fill="none" stroke="var(--border-color)" stroke-width="0.8" opacity="0.6" />
              <path d="M 8 85 L 8 92 L 15 92" fill="none" stroke="var(--border-color)" stroke-width="0.8" opacity="0.6" />
              <path d="M 92 85 L 92 92 L 85 92" fill="none" stroke="var(--border-color)" stroke-width="0.8" opacity="0.6" />
              
              <!-- Crosshair -->
              <line x1="50" y1="20" x2="50" y2="80" stroke="var(--border-color)" stroke-width="0.5" stroke-dasharray="2 2" opacity="0.4" />
              <line x1="20" y1="50" x2="80" y2="50" stroke="var(--border-color)" stroke-width="0.5" stroke-dasharray="2 2" opacity="0.4" />
              <circle cx="50" cy="50" r="8" fill="none" stroke="var(--border-color)" stroke-width="0.6" opacity="0.5" />
            </svg>

            <!-- Static scanline simulation (uses global scanlines background if present, or custom css) -->
            <div class="absolute inset-0 bg-gradient-to-b from-transparent via-text-primary/5 to-transparent pointer-events-none bg-[length:100%_4px] opacity-25"></div>
            
            <!-- Scanner HUD Text Overlay (Bottom status bar) -->
            <div class="absolute bottom-3 left-3 right-3 flex justify-between items-center bg-bg-primary/80 border border-border/80 px-2 py-1 text-[9px] font-mono tracking-widest text-text-primary backdrop-blur-sm">
              <span>SYS_VAL: OK</span>
              <span class="animate-pulse flex items-center gap-1">
                <span class="h-1.5 w-1.5 bg-text-primary rounded-full"></span>
                SCANNING
              </span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
