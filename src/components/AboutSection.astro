---
/* AboutSection.astro — Bold digital editorial profile section */
---

<section id="about" class="border-b border-border grid md:grid-cols-12 w-full">
  <!-- Title & Graphic Column -->
  <div class="md:col-span-4 p-8 sm:p-12 lg:p-16 border-b md:border-b-0 md:border-r border-border flex flex-col justify-between min-h-[350px]">
    <div>
      <div class="reveal font-mono text-[11px] text-text-muted tracking-widest mb-6 flex items-center gap-2">
        <span class="text-text-primary">03.</span> PROFILE
      </div>
      <h2 class="reveal reveal-delay-1 text-3xl sm:text-4xl lg:text-5xl font-black uppercase tracking-tighter leading-[0.9] mb-8">
        The Engineer<br/>Behind<br/>The Work
      </h2>
    </div>
    
    <!-- Profile Photo / Blueprint HUD Overlay Frame -->
    <div class="reveal reveal-delay-2 relative w-32 h-32 border border-border bg-bg-secondary/20 overflow-hidden group">
      <!-- Profile image slot (User can place avatar.jpg inside public/) -->
      <img
        src="/avatar.jpg"
        alt="Profile Avatar"
        class="w-full h-full object-cover filter grayscale group-hover:grayscale-0 transition-all duration-500"
        onerror="this.style.display='none'"
      />
      <!-- Grid blueprint overlay frame -->
      <svg viewBox="0 0 100 100" class="absolute inset-0 w-full h-full pointer-events-none" xmlns="http://www.w3.org/2000/svg">
        <rect x="5" y="5" width="90" height="90" fill="none" stroke="var(--border-color)" stroke-width="0.8" />
        <line x1="5" y1="5" x2="95" y2="95" stroke="var(--border-color)" stroke-width="0.5" opacity="0.4" />
        <line x1="95" y1="5" x2="5" y2="95" stroke="var(--border-color)" stroke-width="0.5" opacity="0.4" />
        <circle cx="50" cy="50" r="18" fill="none" stroke="var(--text-primary)" stroke-width="1" opacity="0.3" />
        <circle cx="50" cy="50" r="2" fill="var(--text-primary)" opacity="0.5" />
      </svg>
    </div>
  </div>

  <!-- Bio & Skills Column -->
  <div class="md:col-span-8 p-8 sm:p-12 lg:p-16 space-y-12 flex flex-col justify-center">
    <!-- Biography -->
    <div class="reveal reveal-delay-1 space-y-6 max-w-2xl text-text-secondary text-sm sm:text-base leading-relaxed font-light">
      <p>
        I'm a full-stack engineer with a focus on building products that people actually want to use.
        I care deeply about clean architecture, performance, and user experience — and I believe the
        best software comes from understanding the problem before writing a single line of code.
      </p>
      <p>
        When I'm not coding, you'll find me exploring new technologies, contributing to open source,
        or diving deep into system design challenges. I'm always looking for opportunities to build
        meaningful products with great teams.
      </p>
    </div>

    <!-- Tech Stack Grid -->
    <div class="reveal reveal-delay-2">
      <div class="font-mono text-[10px] text-text-muted uppercase tracking-widest mb-4 font-bold">
        [ // RELEVANT_STACK ]
      </div>
      <div class="flex flex-wrap gap-1.5 max-w-xl">
        {["React Native", "TypeScript", "Expo", "Supabase", "Python", "FastAPI", "Node.js", "PostgreSQL"].map((tech) => (
          <span class="px-3 py-1.5 text-xs font-mono uppercase tracking-wider border border-border bg-bg-secondary/40 text-text-secondary hover:border-text-primary hover:text-text-primary transition-colors cursor-default">
            {tech}
          </span>
        ))}
      </div>
    </div>

    <!-- Social / External Navigation links -->
    <div class="reveal reveal-delay-3 pt-6 border-t border-border flex flex-wrap gap-6 text-[10px] font-mono tracking-widest uppercase">
      <a
        href="https://github.com/yourusername"
        target="_blank"
        rel="noopener noreferrer"
        class="group flex items-center gap-1.5 text-text-secondary hover:text-text-primary transition-colors focus-ring"
        id="about-github-link"
      >
        <span class="underline-slide">GITHUB</span>
        <span class="text-text-muted group-hover:text-text-primary transition-colors">↗</span>
      </a>
      <a
        href="https://linkedin.com/in/yourusername"
        target="_blank"
        rel="noopener noreferrer"
        class="group flex items-center gap-1.5 text-text-secondary hover:text-text-primary transition-colors focus-ring"
        id="about-linkedin-link"
      >
        <span class="underline-slide">LINKEDIN</span>
        <span class="text-text-muted group-hover:text-text-primary transition-colors">↗</span>
      </a>
    </div>
  </div>
</section>
