---
interface Props {
  title: string;
  description: string;
  tags: string[];
  impact?: string;
  href: string;
  thumbnail?: string;
  index?: number;
}

const { title, description, tags, impact, href, thumbnail, index = 0 } = Astro.props;
const delayClass = `reveal-delay-${Math.min(index + 1, 4)}`;
---

<a
  href={href}
  class={`reveal ${delayClass} group block card-editorial focus-ring`}
>
  <!-- Card Header Index -->
  <div class="flex items-center justify-between border-b border-border group-hover:border-bg-primary/20 p-6 border-editorial-shift">
    <span class="font-mono text-[10px] font-bold tracking-widest text-text-muted group-hover:text-bg-primary/60 transition-colors text-editorial-shift">
      PROJECT {String(index + 1).padStart(2, '0')}
    </span>
    <span class="font-mono text-[10px] text-text-muted group-hover:text-bg-primary/40 transition-colors text-editorial-shift">
      [ // DETAILED_CASE ]
    </span>
  </div>

  <!-- Image/Thumbnail slot -->
  <div class="relative aspect-video border-b border-border group-hover:border-bg-primary/20 bg-bg-secondary overflow-hidden border-editorial-shift">
    {thumbnail ? (
      <img
        src={thumbnail}
        alt={`${title} project screenshot`}
        class="w-full h-full object-cover filter grayscale group-hover:grayscale-0 transition-all duration-500 group-hover:scale-102"
        loading="lazy"
      />
    ) : (
      <div class="w-full h-full flex items-center justify-center bg-bg-secondary/40">
        <div class="text-center px-6">
          <div class="w-12 h-12 mx-auto mb-3 border border-border group-hover:border-bg-primary/30 flex items-center justify-center border-editorial-shift">
            <svg class="w-6 h-6 text-text-muted group-hover:text-bg-primary transition-colors text-editorial-shift" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909M3.75 21h16.5a1.5 1.5 0 001.5-1.5V6a1.5 1.5 0 00-1.5-1.5H3.75A1.5 1.5 0 002.25 6v13.5A1.5 1.5 0 003.75 21z" />
            </svg>
          </div>
          <p class="text-[10px] font-mono uppercase tracking-wider text-text-muted group-hover:text-bg-primary/60 transition-colors text-editorial-shift">Mockup coming soon</p>
        </div>
      </div>
    )}
  </div>

  <!-- Card Body -->
  <div class="p-6 flex flex-col justify-between min-h-[200px]">
    <div>
      <h3 class="text-xl font-black uppercase tracking-tight text-text-primary group-hover:text-bg-primary transition-colors mb-3 text-editorial-shift">
        {title}
      </h3>
      <p class="text-text-secondary group-hover:text-bg-primary/80 transition-colors text-xs leading-relaxed mb-6 text-editorial-shift">
        {description}
      </p>
    </div>

    <div>
      {impact && (
        <div class="flex items-center gap-1.5 mb-4 px-2.5 py-1 border border-border group-hover:border-bg-primary/30 bg-bg-secondary group-hover:bg-bg-primary/10 w-fit border-editorial-shift">
          <svg class="w-3.5 h-3.5 text-text-primary group-hover:text-bg-primary transition-colors text-editorial-shift flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />
          </svg>
          <span class="text-[10px] font-mono font-bold uppercase tracking-wider text-text-primary group-hover:text-bg-primary transition-colors text-editorial-shift">{impact}</span>
        </div>
      )}

      <div class="flex flex-wrap gap-1.5 mb-6">
        {tags.map((tag) => (
          <span class="px-2 py-0.5 text-[9px] font-mono uppercase tracking-wider border border-border group-hover:border-bg-primary/25 bg-bg-secondary/40 group-hover:bg-bg-primary/5 text-text-secondary group-hover:text-bg-primary transition-colors border-editorial-shift text-editorial-shift">
            {tag}
          </span>
        ))}
      </div>

      <div class="flex items-center gap-1.5 text-[10px] font-mono uppercase tracking-widest text-text-primary group-hover:text-bg-primary transition-all text-editorial-shift">
        <span>[ View Case Study ]</span>
        <svg class="w-3.5 h-3.5 transition-transform duration-300 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </div>
    </div>
  </div>
</a>
