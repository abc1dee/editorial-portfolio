---
import InteractiveBackground from "../components/InteractiveBackground.astro";

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = "Full-Stack Engineer building products that solve real problems — from mobile apps to backend systems.",
  ogImage = "/og-image.webp",
} = Astro.props;
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:type" content="website" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Preconnect for fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <!-- Global Styles -->
    <title>{title}</title>

    <style>
      /* Critical CSS — prevents FOUC */
      html { background-color: #000000; color: #ffffff; }
      html:not(.dark) { background-color: #ffffff; color: #09090b; }
    </style>
  </head>
  <body class="min-h-screen bg-bg-primary text-text-primary relative overflow-x-hidden">
    <div class="max-w-6xl mx-auto border-x border-border min-h-screen flex flex-col relative bg-bg-primary">
      <InteractiveBackground />
      <slot />
    </div>

    <!-- Scroll Reveal Observer — zero-library, ~15 lines -->
    <script>
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add("visible");
            } else {
              entry.target.classList.remove("visible");
            }
          });
        },
        { threshold: 0.05 } // slightly lower threshold for smoother enter/exit transitions
      );

      document.querySelectorAll(".reveal").forEach((el) => observer.observe(el));
    </script>
  </body>
</html>
